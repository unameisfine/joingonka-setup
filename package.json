{
  "name": "@joingonka/setup",
  "version": "0.2.1",
  "description": "One-command installer to point eight agentic AI coding tools (Claude Code, OpenClaw, Cline, opencode, Aider, Kilo, Roo, Continue) at JoinGonka Gateway — a cheap, OpenAI- and Anthropic-compatible API for decentralized Gonka AI inference",
  "type": "module",
  "bin": {
    "joingonka-setup": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "@inquirer/prompts": "^5.0.0",
    "write-file-atomic": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/write-file-atomic": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "claude-code",
    "openclaw",
    "cline",
    "opencode",
    "aider",
    "kilo-code",
    "roo-code",
    "continue-dev",
    "anthropic",
    "anthropic-api",
    "openai-compatible",
    "ai",
    "llm",
    "cheap-ai-api",
    "cheapest-ai-api",
    "ai-coding-agent",
    "decentralized-ai",
    "gonka",
    "gonka-ai",
    "joingonka",
    "cli",
    "installer"
  ],
  "author": "JoinGonka <support@joingonka.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/unameisfine/joingonka-setup"
  }
}
